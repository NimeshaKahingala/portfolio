---
interface Props {
  eyebrow: string;
  title: string;
  linkHref?: string;
  linkLabel?: string;
}
const { eyebrow, title, linkHref, linkLabel } = Astro.props;
---

<div class="section-heading">
  <div>
    <p class="eyebrow">{eyebrow}</p>
    <h2 class="h2">{title}</h2>
  </div>
  {
    linkHref && linkLabel && (
      <a class="link-arrow" href={linkHref}>
        {linkLabel}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
    )
  }
</div>

<style>
  .section-heading {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }
  .section-heading .h2 {
    margin-top: 0.625rem;
  }
  .link-arrow {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    color: var(--accent);
    white-space: nowrap;
  }
  .link-arrow svg {
    width: 15px;
    height: 15px;
    transition: transform 0.2s ease;
  }
  .link-arrow:hover svg {
    transform: translateX(4px);
  }
</style>
