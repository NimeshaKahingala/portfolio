---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
---

<Base title="Page not found — Nimesha Kahingala" noindex>
  <section class="notfound">
    <div class="container notfound-inner">
      <p class="eyebrow">404</p>
      <h1 class="h1">This page doesn't exist.</h1>
      <p class="body-lg notfound-desc prose-measure">
        The link may be broken, or the page may have moved. Let's get you back
        on track.
      </p>
      <div class="notfound-actions">
        <Button href="/" variant="primary">Back home</Button>
        <Button href="/portfolio/" variant="secondary">View work</Button>
      </div>
    </div>
  </section>
</Base>

<style>
  .notfound {
    display: grid;
    place-items: center;
    min-height: 60vh;
    padding: 4rem 0;
    text-align: center;
  }
  .notfound-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .eyebrow {
    margin-bottom: 1rem;
  }
  .notfound-desc {
    color: var(--muted);
    margin: 1rem 0 2rem;
  }
  .notfound-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
